# DeviQ Environment Variables

# TCS GenAI Lab (LiteLLM Proxy)
VITE_LLM_API_KEY=your_llm_api_key_here
VITE_LLM_BASE_URL=https://genailab.tcs.in/lite/v1

# RAG Backend (Python FastAPI server — see RAG/start_rag.bat)
VITE_RAG_API_URL=http://localhost:8001

# Supabase (Optional — app works without it via local auth)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here
